<view class="page page-tight">
  <view class="hero hero-member home-hero">
    <view class="hero-badge">我的会员</view>
    <view class="title">{{statusHeadline}}</view>
    <view class="subtitle">{{statusSummary}}</view>
    <view class="mini-metrics home-metrics">
      <view class="mini-metric">
        <view class="mini-metric-label">会员</view>
        <view class="mini-metric-value">{{memberStatusText}}</view>
      </view>
      <view class="mini-metric">
        <view class="mini-metric-label">邀请</view>
        <view class="mini-metric-value">{{inviteStatusText}}</view>
      </view>
      <view class="mini-metric">
        <view class="mini-metric-label">积分</view>
        <view class="mini-metric-value">{{pointsBalance}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card">
    <view class="section-title">加载中</view>
    <view class="section-copy">正在读取会员信息。</view>
  </view>

  <view wx:if="{{errorMessage}}" class="card card-accent">
    <view class="section-title">提示</view>
    <view class="notice">{{errorMessage}}</view>
    <button class="button-secondary" bindtap="refresh">重新加载</button>
  </view>

  <view wx:if="{{member}}" class="card card-soft home-card">
    <view class="card-header-row">
      <view class="card-title-wrap">
        <view class="section-kicker">当前状态</view>
        <view class="section-title">{{nextStepTitle}}</view>
        <view class="card-subtitle">{{nextStepCopy}}</view>
      </view>
      <view class="tag {{memberStatusText === '已开通' ? 'tag-success' : ''}}">{{memberStatusText}}</view>
    </view>

    <view class="member-brief">
      <view class="member-brief-item">
        <view class="member-brief-label">会员号</view>
        <view class="member-brief-value">{{member.memberCode}}</view>
      </view>
      <view class="member-brief-item">
        <view class="member-brief-label">手机号</view>
        <view class="member-brief-value">{{memberPhoneText}}</view>
      </view>
      <view class="member-brief-item">
        <view class="member-brief-label">积分</view>
        <view class="member-brief-value">{{pointsBalance}}</view>
      </view>
    </view>

    <view class="status-list">
      <view wx:for="{{statusItems}}" wx:key="key" class="status-item">
        <view class="status-main">
          <view class="status-label">{{item.label}}</view>
          <view class="status-detail">{{item.detail}}</view>
        </view>
        <view class="status-pill {{item.tone === 'success' ? 'status-pill-success' : item.tone === 'warning' ? 'status-pill-warning' : 'status-pill-neutral'}}">{{item.value}}</view>
      </view>
    </view>

    <view class="button-group home-actions">
      <button wx:if="{{showRegisterButton}}" class="button-primary" bindtap="goRegister">验证手机号</button>
      <button wx:else class="button-primary" bindtap="goVouchers">积分和券</button>
      <button wx:if="{{!showRegisterButton}}" class="button-secondary" bindtap="goMemberCard">会员码</button>
    </view>
  </view>

  <view class="card home-card">
    <view class="section-kicker">会员服务</view>
    <view class="section-title">常用入口</view>
    <view class="card-subtitle">订单、邀请、券包都从这里进。</view>

    <view class="quick-grid home-quick-grid">
      <view class="quick-card home-quick-card" bindtap="goOrders">
        <view class="quick-card-tag">订单</view>
        <view class="quick-card-title">我的订单</view>
        <view class="quick-card-copy">看状态和历史订单。</view>
      </view>

      <navigator class="quick-card home-quick-card" url="/pages/vouchers/vouchers">
        <view class="quick-card-tag">积分</view>
        <view class="quick-card-title">积分和券</view>
        <view class="quick-card-copy">查看积分，兑换菜品。</view>
      </navigator>

      <navigator wx:if="{{showInviteEntry}}" class="quick-card home-quick-card" url="/pages/invite/invite">
        <view class="quick-card-tag">邀请</view>
        <view class="quick-card-title">邀请中心</view>
        <view class="quick-card-copy">分享邀请码，看邀请进度。</view>
      </navigator>

      <navigator class="quick-card home-quick-card" url="/pages/member-card/member-card">
        <view class="quick-card-tag">会员码</view>
        <view class="quick-card-title">我的会员码</view>
        <view class="quick-card-copy">到店出示即可。</view>
      </navigator>

      <navigator class="quick-card home-quick-card" url="/pages/records/records">
        <view class="quick-card-tag">记录</view>
        <view class="quick-card-title">消费记录</view>
        <view class="quick-card-copy">查看首单和历史消费。</view>
      </navigator>

      <navigator class="quick-card home-quick-card" url="/pages/rules/rules">
        <view class="quick-card-tag">规则</view>
        <view class="quick-card-title">活动规则</view>
        <view class="quick-card-copy">注册、邀请、用券说明。</view>
      </navigator>

      <view class="quick-card home-quick-card" bindtap="goFeedback">
        <view class="quick-card-tag">反馈</view>
        <view class="quick-card-title">问题反馈</view>
        <view class="quick-card-copy">页面、积分、券问题都能提。</view>
      </view>
    </view>
  </view>
</view>
