<view class="page page-tight">
  <view class="hero hero-staff staff-home-hero">
    <view class="hero-topline">
      <view class="hero-badge">{{hasSession ? '店员' : '店员入口'}}</view>
      <view wx:if="{{hasSession && staffRoleLabel}}" class="hero-table-chip hero-table-chip-light">{{staffRoleLabel}}</view>
    </view>
    <view class="title">{{hasSession ? workHintTitle : '先登录店员账号'}}</view>
    <view class="subtitle">{{workHintCopy}}</view>
    <view class="staff-status-strip">
      <view class="staff-status-chip">
        <view class="staff-status-label">状态</view>
        <view class="staff-status-value">{{loginStatusText}}</view>
      </view>
      <view class="staff-status-chip">
        <view class="staff-status-label">账号</view>
        <view class="staff-status-value">{{hasSession && staffProfile ? staffProfile.username : '待登录'}}</view>
      </view>
      <view class="staff-status-chip">
        <view class="staff-status-label">刷新</view>
        <view class="staff-status-value">下拉即可</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card">
    <view class="section-title">加载中</view>
    <view class="section-copy">正在检查登录状态。</view>
  </view>

  <view wx:if="{{errorMessage}}" class="card card-accent">
    <view class="section-title">提示</view>
    <view class="notice">{{errorMessage}}</view>
    <button class="button-secondary" bindtap="goLogin">重新登录</button>
  </view>

  <view wx:if="{{!loading && !hasSession}}" class="card card-soft staff-login-card">
    <view class="section-kicker">登录</view>
    <view class="section-title">店员登录</view>
    <view class="section-copy">用老板创建的账号登录。</view>
    <button class="button-primary" bindtap="goLogin">去登录</button>
  </view>

  <block wx:if="{{hasSession && staffProfile}}">
    <view class="card card-soft staff-work-card">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-kicker">高频</view>
          <view class="section-title">常用操作</view>
          <view class="card-subtitle">先做核销和消费结算。</view>
        </view>
        <view class="tag tag-success">在线</view>
      </view>

      <view class="staff-primary-grid">
        <view class="staff-task-card staff-task-card-primary" bindtap="goVoucher">
          <view class="quick-card-tag">核销</view>
          <view class="staff-task-title">菜品券核销</view>
          <view class="staff-task-copy">扫码优先，也能手输。</view>
        </view>

        <view class="staff-task-card" bindtap="goVisit">
          <view class="quick-card-tag">消费</view>
          <view class="staff-task-title">消费核销</view>
          <view class="staff-task-copy">查会员后录订单号。</view>
        </view>
      </view>
    </view>

    <view class="card staff-tools-card">
      <view class="section-kicker">其他</view>
      <view class="section-title">更多功能</view>

      <view class="quick-grid staff-tools-grid">
        <view class="quick-card staff-tool-card" bindtap="goSearch">
          <view class="quick-card-tag">会员</view>
          <view class="quick-card-title">会员查询</view>
          <view class="quick-card-copy">查状态、积分、券。</view>
        </view>

        <view class="quick-card staff-tool-card" bindtap="goOrders">
          <view class="quick-card-tag">订单</view>
          <view class="quick-card-title">订单看板</view>
          <view class="quick-card-copy">查看和处理订单。</view>
        </view>

        <view class="quick-card staff-tool-card" bindtap="goFeedback">
          <view class="quick-card-tag">反馈</view>
          <view class="quick-card-title">问题反馈</view>
          <view class="quick-card-copy">现场异常直接提交。</view>
        </view>

        <view class="quick-card staff-tool-card" bindtap="logout">
          <view class="quick-card-tag">账号</view>
          <view class="quick-card-title">退出登录</view>
          <view class="quick-card-copy">换人值班时退出。</view>
        </view>
      </view>
    </view>
  </block>
</view>
