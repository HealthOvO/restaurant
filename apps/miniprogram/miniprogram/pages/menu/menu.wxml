<view class="page menu-shell">
  <view class="card menu-header-card">
    <view class="menu-header-main">
      <view class="menu-header-copy">
        <view class="section-kicker">菜单</view>
        <view class="section-title">{{storeConfig ? storeConfig.storeName : '门店菜单'}}</view>
        <view class="card-subtitle">{{storeConfig && storeConfig.announcement ? storeConfig.announcement : '选好直接加入购物车。'}}</view>
      </view>
      <view class="menu-header-summary">
        <view class="menu-header-count">{{cartItemCount ? (cartItemCount + ' 件') : '0 件'}}</view>
        <view class="menu-header-amount">¥{{cartTotalAmountText}}</view>
      </view>
    </view>

    <view class="menu-header-meta">
      <view class="menu-header-pill">{{storeConfig && storeConfig.dineInEnabled ? '堂食' : '堂食暂停'}}</view>
      <view class="menu-header-pill">{{storeConfig && storeConfig.pickupEnabled ? '自提' : '自提暂停'}}</view>
      <view wx:if="{{activeTableNo}}" class="menu-header-pill">桌号 {{activeTableNo}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card">
    <view class="section-title">加载中</view>
    <view class="section-copy">正在同步菜单。</view>
  </view>

  <view wx:if="{{errorMessage}}" class="card card-accent">
    <view class="section-title">提示</view>
    <view class="notice">{{errorMessage}}</view>
    <button class="button-secondary" bindtap="refresh">重新加载</button>
  </view>

  <view class="menu-board">
    <scroll-view class="menu-side-nav" scroll-y="true" enhanced="true" show-scrollbar="false">
      <view
        wx:for="{{categories}}"
        wx:for-item="category"
        wx:key="_id"
        class="menu-side-item {{category._id === activeCategoryId ? 'menu-side-item-active' : ''}}"
        data-category-id="{{category._id}}"
        bindtap="selectCategory"
      >
        <view class="menu-side-name">{{category.name}}</view>
        <view class="menu-side-count">{{category.itemCount}}</view>
      </view>
    </scroll-view>

    <scroll-view class="menu-main-panel" scroll-y="true" enhanced="true" show-scrollbar="false">
      <view class="menu-main-head">
        <view class="menu-main-title">{{activeCategoryName || '菜品'}}</view>
        <view class="menu-main-subtitle">{{visibleItems.length ? ('共 ' + visibleItems.length + ' 款') : '本分类暂无菜品'}}</view>
      </view>

      <view class="menu-list">
        <view wx:for="{{visibleItems}}" wx:for-item="menuItem" wx:key="_id" class="menu-item-card">
          <view class="menu-item-head">
            <view class="menu-item-copy">
              <view class="menu-item-name">{{menuItem.name}}</view>
              <view class="menu-item-desc">{{menuItem.description || '现点现做。'}}</view>
              <view class="menu-item-tags">
                <view wx:for="{{menuItem.tags}}" wx:for-item="tag" wx:key="*this" class="menu-item-tag">{{tag}}</view>
                <view wx:if="{{menuItem.optionHint}}" class="menu-item-tag menu-item-tag-muted">{{menuItem.optionHint}}</view>
              </view>
            </view>
          </view>

          <view class="menu-item-foot">
            <view class="menu-item-side">
              <view class="menu-item-price">{{menuItem.priceText}}</view>
              <view class="menu-item-sales">{{menuItem.salesText}} · {{menuItem.isSoldOut ? '已售罄' : (menuItem.isRecommended ? '推荐' : '在售')}}</view>
            </view>
            <button class="button-primary menu-add-button" data-item-id="{{menuItem._id}}" disabled="{{menuItem.isSoldOut}}" bindtap="quickAdd">
              {{menuItem.optionGroups && menuItem.optionGroups.length ? '选规格' : '加购'}}
            </button>
          </view>
        </view>

        <view wx:if="{{!loading && !visibleItems.length}}" class="empty-state">
          <view class="tag">暂无菜品</view>
          <view class="empty-title">这个分类暂时没有菜</view>
          <view class="empty-copy">换个分类试试。</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="cart-bar">
    <view class="cart-bar-main">
      <view class="cart-bar-title">{{cartItemCount ? ('已选 ' + cartItemCount + ' 件') : '购物车为空'}}</view>
      <view class="cart-bar-copy">{{cartItemCount ? ('合计 ¥' + cartTotalAmountText) : '先加几样菜'}}</view>
    </view>
    <view class="cart-bar-actions">
      <button wx:if="{{cartItemCount}}" class="button-secondary cart-bar-button" bindtap="goOrders">订单</button>
      <button class="button-primary cart-bar-button" bindtap="goCheckout">去结算</button>
    </view>
  </view>

  <view wx:if="{{cartItemCount}}" class="card cart-inline-card">
    <view class="card-header-row">
      <view class="card-title-wrap">
        <view class="section-kicker">购物车</view>
        <view class="section-title">已选菜品</view>
        <view class="card-subtitle">这里可以改数量。</view>
      </view>
      <view class="tag">{{cartItemCount}} 件</view>
    </view>
    <view wx:for="{{cartItems}}" wx:for-item="cartLine" wx:key="lineId" class="cart-inline-item">
      <view class="cart-inline-copy">
        <view class="cart-inline-name">{{cartLine.name}}</view>
        <view class="cart-inline-meta">{{cartLine.selectedOptionsText || '默认规格'}}</view>
      </view>
      <view class="cart-inline-side">
        <view class="cart-inline-price">¥{{cartLine.lineTotalText}}</view>
        <view class="cart-stepper">
          <view class="cart-stepper-button" data-line-id="{{cartLine.lineId}}" bindtap="decreaseCartItem">-</view>
          <view class="cart-stepper-count">{{cartLine.quantity}}</view>
          <view class="cart-stepper-button" data-line-id="{{cartLine.lineId}}" bindtap="increaseCartItem">+</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{optionSheetVisible && activeMenuItem}}" class="overlay-mask" catchtouchmove="noop" bindtap="closeOptionSheet">
    <view class="dialog-sheet option-sheet" catchtap="noop">
      <view class="section-kicker">选规格</view>
      <view class="section-title">{{activeMenuItem.name}}</view>
      <view class="section-copy">{{activeMenuItem.descriptionText}}</view>

      <view wx:for="{{activeMenuItem.optionGroups}}" wx:for-item="group" wx:key="_id" class="option-group">
        <view class="option-group-title">{{group.titleText}}</view>
        <view class="option-choice-row">
          <view
            wx:for="{{group.choices}}"
            wx:for-item="choice"
            wx:key="_id"
            class="{{choice.className}}"
            data-group-id="{{group._id}}"
            data-choice-id="{{choice._id}}"
            bindtap="toggleOption"
          >
            {{choice.name}}{{choice.priceDeltaText}}{{choice.statusText}}
          </view>
        </view>
      </view>

      <view class="button-group option-sheet-actions">
        <button class="button-primary" bindtap="confirmOptionSelection">加入购物车</button>
        <button class="button-secondary" bindtap="closeOptionSheet">取消</button>
      </view>
    </view>
  </view>
</view>
