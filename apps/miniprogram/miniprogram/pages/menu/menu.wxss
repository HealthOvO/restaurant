.menu-shell {
  padding-top: 18rpx;
  padding-bottom: 220rpx;
}

.menu-hero {
  padding: 34rpx 28rpx 30rpx;
}

.menu-category-row {
  display: flex;
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.menu-category-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid #e8d7c1;
  color: #6c5943;
  font-size: 24rpx;
  font-weight: 700;
}

.menu-category-pill-active {
  background: #9a3529;
  border-color: #9a3529;
  color: #ffffff;
}

.menu-list {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.menu-item-card {
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(236, 224, 205, 0.86);
  box-shadow: 0 18rpx 36rpx rgba(45, 31, 20, 0.08);
}

.menu-item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
}

.menu-item-copy {
  flex: 1;
  min-width: 0;
}

.menu-item-name {
  font-size: 31rpx;
  font-weight: 700;
  color: #1f2330;
}

.menu-item-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.68;
  color: #73695d;
}

.menu-item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.menu-item-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f8ead7;
  color: #8b5e05;
  font-size: 20rpx;
  font-weight: 700;
}

.menu-item-tag-muted {
  background: #f5efe6;
  color: #6e6359;
}

.menu-item-side {
  display: grid;
  justify-items: end;
  gap: 8rpx;
}

.menu-item-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #9a3529;
}

.menu-item-sales {
  font-size: 21rpx;
  color: #857666;
}

.menu-item-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #efe3d5;
}

.menu-item-status {
  font-size: 22rpx;
  color: #7b7062;
}

.menu-add-button {
  margin-top: 0;
  min-height: 72rpx;
  padding: 0 28rpx;
  font-size: 24rpx;
}

.cart-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(34, 27, 21, 0.9);
  box-shadow: 0 24rpx 48rpx rgba(18, 13, 10, 0.24);
  z-index: 20;
}

.cart-bar-main {
  flex: 1;
  min-width: 0;
}

.cart-bar-title {
  color: #fffaf4;
  font-size: 28rpx;
  font-weight: 700;
}

.cart-bar-copy {
  margin-top: 6rpx;
  color: rgba(255, 250, 244, 0.72);
  font-size: 22rpx;
}

.cart-bar-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cart-bar-button {
  margin-top: 0;
  min-height: 70rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.cart-inline-card {
  margin-top: 22rpx;
}

.cart-inline-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #efe3d5;
}

.cart-inline-item:first-child {
  border-top: none;
  padding-top: 8rpx;
}

.cart-inline-copy {
  flex: 1;
  min-width: 0;
}

.cart-inline-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2330;
}

.cart-inline-meta {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #73695d;
  line-height: 1.6;
}

.cart-inline-side {
  display: grid;
  justify-items: end;
  gap: 10rpx;
}

.cart-inline-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #9a3529;
}

.cart-stepper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.cart-stepper-button {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f6ead0;
  color: #8b5e05;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
  font-weight: 700;
}

.cart-stepper-count {
  min-width: 26rpx;
  text-align: center;
  font-size: 24rpx;
  color: #1f2330;
  font-weight: 700;
}

.option-sheet {
  padding: 32rpx 28rpx;
}

.option-group {
  margin-top: 18rpx;
}

.option-group-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2330;
}

.option-choice-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.option-choice {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f7f1e7;
  border: 1rpx solid #e8d7c1;
  color: #6c5943;
  font-size: 22rpx;
}

.option-choice-disabled {
  background: #f5f2ed;
  border-color: #e7ddd0;
  color: #aa9f91;
}

.option-choice-active {
  background: #9a3529;
  border-color: #9a3529;
  color: #ffffff;
}
