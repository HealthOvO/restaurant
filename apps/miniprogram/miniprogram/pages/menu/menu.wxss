.menu-shell {
  padding-top: 18rpx;
  padding-bottom: 220rpx;
}

.menu-header-card {
  margin-top: 0;
}

.menu-header-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.menu-header-copy {
  flex: 1;
  min-width: 0;
}

.menu-header-summary {
  min-width: 150rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: #fff8ef;
  border: 1rpx solid #ead7bf;
  text-align: right;
}

.menu-header-count {
  font-size: 22rpx;
  color: #816349;
}

.menu-header-amount {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #9a3529;
}

.menu-header-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.menu-header-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff8ef;
  border: 1rpx solid #ead7bf;
  color: #74411e;
  font-size: 22rpx;
  font-weight: 700;
}

.menu-board {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
  height: calc(100vh - 500rpx);
  min-height: 760rpx;
}

.menu-side-nav {
  width: 176rpx;
  height: 100%;
  padding: 10rpx;
  border-radius: 24rpx;
  background: rgba(255, 250, 243, 0.92);
  border: 1rpx solid #eadcc8;
  box-sizing: border-box;
}

.menu-side-item {
  display: grid;
  gap: 8rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  color: #6f6559;
  transition: background 180ms ease, color 180ms ease;
}

.menu-side-item + .menu-side-item {
  margin-top: 8rpx;
}

.menu-side-item-active {
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(45, 31, 20, 0.06);
  color: #9a3529;
}

.menu-side-name {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.menu-side-count {
  font-size: 20rpx;
  color: inherit;
  opacity: 0.8;
}

.menu-main-panel {
  flex: 1;
  height: 100%;
  padding: 6rpx;
  box-sizing: border-box;
}

.menu-main-head {
  padding: 4rpx 8rpx 18rpx;
}

.menu-main-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2330;
}

.menu-main-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7b7062;
}

.menu-list {
  display: grid;
  gap: 16rpx;
}

.menu-item-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  border: 1rpx solid rgba(236, 224, 205, 0.86);
  box-shadow: 0 10rpx 22rpx rgba(45, 31, 20, 0.05);
}

.menu-item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.menu-item-copy {
  flex: 1;
  min-width: 0;
}

.menu-item-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2330;
}

.menu-item-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.56;
  color: #73695d;
}

.menu-item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.menu-item-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f8ead7;
  color: #8b5e05;
  font-size: 20rpx;
  font-weight: 700;
}

.menu-item-tag-muted {
  background: #f5efe6;
  color: #6e6359;
}

.menu-item-side {
  display: grid;
  justify-items: end;
  gap: 8rpx;
}

.menu-item-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #9a3529;
}

.menu-item-sales {
  font-size: 21rpx;
  color: #857666;
}

.menu-item-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #efe3d5;
}

.menu-item-status {
  font-size: 22rpx;
  color: #7b7062;
}

.menu-add-button {
  margin-top: 0;
  min-height: 68rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.cart-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(34, 27, 21, 0.92);
  box-shadow: 0 18rpx 38rpx rgba(18, 13, 10, 0.18);
  z-index: 20;
}

.cart-bar-main {
  flex: 1;
  min-width: 0;
}

.cart-bar-title {
  color: #fffaf4;
  font-size: 28rpx;
  font-weight: 700;
}

.cart-bar-copy {
  margin-top: 6rpx;
  color: rgba(255, 250, 244, 0.72);
  font-size: 22rpx;
}

.cart-bar-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cart-bar-button {
  margin-top: 0;
  min-height: 68rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.cart-inline-card {
  margin-top: 22rpx;
}

.cart-inline-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #efe3d5;
}

.cart-inline-item:first-child {
  border-top: none;
  padding-top: 8rpx;
}

.cart-inline-copy {
  flex: 1;
  min-width: 0;
}

.cart-inline-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2330;
}

.cart-inline-meta {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #73695d;
  line-height: 1.6;
}

.cart-inline-side {
  display: grid;
  justify-items: end;
  gap: 10rpx;
}

.cart-inline-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #9a3529;
}

.cart-stepper {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.cart-stepper-button {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f6ead0;
  color: #8b5e05;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
  font-weight: 700;
}

.cart-stepper-count {
  min-width: 26rpx;
  text-align: center;
  font-size: 24rpx;
  color: #1f2330;
  font-weight: 700;
}

.option-sheet {
  padding: 32rpx 28rpx;
}

.option-group {
  margin-top: 18rpx;
}

.option-group-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2330;
}

.option-choice-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.option-choice {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f7f1e7;
  border: 1rpx solid #e8d7c1;
  color: #6c5943;
  font-size: 22rpx;
}

.option-choice-disabled {
  background: #f5f2ed;
  border-color: #e7ddd0;
  color: #aa9f91;
}

.option-choice-active {
  background: #9a3529;
  border-color: #9a3529;
  color: #ffffff;
}

@media (max-width: 420px) {
  .menu-board {
    gap: 12rpx;
  }

  .menu-side-nav {
    width: 164rpx;
  }
}
