<view class="page page-tight">
  <view wx:if="{{member}}">
    <view class="hero hero-member">
      <view class="hero-badge">会员凭证</view>
      <view class="title">到店出示会员码</view>
      <view class="subtitle">到店时出示给店员就行。</view>
      <view class="mini-metrics">
        <view class="mini-metric">
          <view class="mini-metric-label">手机号</view>
          <view class="mini-metric-value">{{maskedPhone || '未绑定'}}</view>
        </view>
        <view class="mini-metric">
          <view class="mini-metric-label">验证状态</view>
          <view class="mini-metric-value">{{phoneStatusText}}</view>
        </view>
        <view class="mini-metric">
          <view class="mini-metric-label">首单进度</view>
          <view class="mini-metric-value">{{member.hasCompletedFirstVisit ? '已激活' : '待首单'}}</view>
        </view>
      </view>
    </view>

    <view class="card card-accent identity-card">
      <view class="section-kicker">本次到店出示</view>
      <view class="section-title">会员号凭证</view>
      <view class="section-copy">扫码或直接报会员号都可以。</view>

      <view class="member-qr-panel">
        <view class="qr-preview-shell member-qr-shell">
          <canvas
            canvas-id="{{qrCanvasId}}"
            class="member-qr-canvas"
            disable-scroll="true"
            style="width: 420rpx; height: 420rpx;"
            width="{{qrCanvasSize}}"
            height="{{qrCanvasSize}}"
          ></canvas>
        </view>
        <view wx:if="{{qrError}}" class="notice qr-notice">{{qrError}}</view>
        <view wx:else class="helper-text member-qr-helper">
          店员可在“消费核销”或“会员查询”里扫码。
        </view>
      </view>

      <view class="code-panel">
        <view class="code-label">会员号</view>
        <view class="code-value">{{member.memberCode}}</view>
        <view class="code-caption">扫不了码就直接报会员号。</view>
      </view>

      <view class="detail-grid">
        <view class="detail-row">
          <view class="detail-label">手机号状态</view>
          <view class="detail-value">{{phoneStatusText}}</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">首次消费状态</view>
          <view class="detail-value">{{member.hasCompletedFirstVisit ? '已完成首次有效消费' : '还未完成首次有效消费'}}</view>
        </view>
      </view>

      <view class="button-group">
        <button class="button-primary" bindtap="copyMemberCode">复制会员号</button>
        <navigator class="link-button button-secondary" url="/pages/invite/invite">去邀请好友</navigator>
        <navigator class="link-button button-secondary" url="/pages/vouchers/vouchers">查看我的菜品券</navigator>
      </view>
    </view>
  </view>

  <view wx:else class="card">
    <view class="section-title">还没有会员资料</view>
    <view class="section-copy">先完成会员注册和手机号验证，注册后这里会显示会员号。</view>
    <navigator class="link-button button-primary" url="/pages/index/index">返回首页</navigator>
  </view>
</view>
