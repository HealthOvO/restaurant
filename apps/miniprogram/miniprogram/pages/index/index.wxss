.home-shell {
  padding-top: 18rpx;
}

.dining-hero {
  padding: 30rpx 28rpx;
}

.hero-topline {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-table-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff5e8;
  font-size: 22rpx;
  font-weight: 700;
}

.home-primary-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.home-primary-button,
.home-secondary-button {
  margin-top: 0;
  min-height: 78rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.home-summary-card {
  margin-top: 22rpx;
}

.home-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.home-summary-item {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: #fffaf3;
  border: 1rpx solid #ecdcc8;
}

.home-summary-label {
  font-size: 21rpx;
  color: #7b7062;
}

.home-summary-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2330;
  line-height: 1.4;
}

.home-recommend-list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.home-shortcuts-card {
  margin-top: 22rpx;
}

.home-shortcuts-grid {
  margin-top: 18rpx;
}

.home-shortcut-card {
  background: #fffaf3;
  border-color: rgba(229, 212, 188, 0.92);
  box-shadow: none;
}

.home-category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.home-category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f6efe4;
  color: #6d5f52;
  font-size: 22rpx;
}

.home-dish-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #efe3d5;
}

.home-dish-item:first-child {
  padding-top: 8rpx;
  border-top: none;
}

.home-dish-copy {
  flex: 1;
  min-width: 0;
}

.home-dish-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2330;
}

.home-dish-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.56;
  color: #73695d;
}

.home-dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.home-dish-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f8ead7;
  color: #8b5e05;
  font-size: 20rpx;
  font-weight: 700;
}

.home-dish-side {
  display: grid;
  justify-items: end;
  gap: 8rpx;
}

.home-dish-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #9a3529;
}

.home-dish-sales {
  font-size: 21rpx;
  color: #8b7b67;
}

.home-summary-actions,
.home-footer-actions {
  margin-top: 18rpx;
}

@media (max-width: 420px) {
  .home-primary-actions {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-summary-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
