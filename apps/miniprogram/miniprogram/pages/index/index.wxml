<view class="page home-shell">
  <view class="hero hero-member dining-hero">
    <view class="hero-topline">
      <view class="hero-badge">点餐</view>
      <view wx:if="{{activeTableNo}}" class="hero-table-chip">桌号 {{activeTableNo}}</view>
    </view>
    <view class="title">{{storeConfig ? storeConfig.storeName : '门店点餐'}}</view>
    <view class="subtitle">{{storeConfig && storeConfig.announcement ? storeConfig.announcement : '点餐、下单、看订单。'}}</view>

    <view class="hero-chips">
      <view class="hero-chip">{{storeConfig && storeConfig.dineInEnabled ? '堂食' : '堂食暂停'}}</view>
      <view class="hero-chip">{{storeConfig && storeConfig.pickupEnabled ? '自提' : '自提暂停'}}</view>
      <view class="hero-chip">{{hasMember ? '会员已开通' : '先注册会员'}}</view>
    </view>

    <view class="home-primary-actions">
      <button class="button-primary home-primary-button" bindtap="goMenu">去点餐</button>
      <button class="button-secondary home-secondary-button" bindtap="goOrders">订单</button>
      <button class="button-secondary home-secondary-button" bindtap="goMine">我的</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card">
    <view class="section-title">加载中</view>
    <view class="section-copy">正在读取门店信息。</view>
  </view>

  <view wx:if="{{errorMessage}}" class="card card-accent">
    <view class="section-title">提示</view>
    <view class="notice">{{errorMessage}}</view>
    <button class="button-secondary" bindtap="refresh">重新加载</button>
  </view>

  <view wx:if="{{inviteReminder}}" class="card card-soft home-summary-card">
    <view class="card-header-row">
      <view class="card-title-wrap">
        <view class="section-kicker">邀请</view>
        <view class="section-title">{{inviteReminder.title}}</view>
        <view class="card-subtitle">{{inviteReminder.copy}}</view>
      </view>
      <view class="tag">{{inviteReminder.statusText}}</view>
    </view>
    <view class="button-group-tight home-summary-actions">
      <button class="button-primary" bindtap="goInviteCenter">{{inviteReminder.statusText === '待绑定' ? '去绑定' : '查看邀请'}}</button>
      <button class="button-secondary" bindtap="goMenu">继续点餐</button>
    </view>
  </view>

  <view class="card card-soft home-summary-card">
    <view class="card-header-row">
      <view class="card-title-wrap">
        <view class="section-kicker">会员</view>
        <view class="section-title">{{memberActionTitle}}</view>
        <view class="card-subtitle">{{memberActionCopy}}</view>
      </view>
      <view class="tag {{hasMember && memberStatusText !== '待验证' ? 'tag-success' : ''}}">{{memberStatusText}}</view>
    </view>

    <view class="home-summary-grid">
      <view class="home-summary-item">
        <view class="home-summary-label">状态</view>
        <view class="home-summary-value">{{memberStatusText}}</view>
      </view>
      <view class="home-summary-item">
        <view class="home-summary-label">积分</view>
        <view class="home-summary-value">{{pointsBalance}}</view>
      </view>
      <view class="home-summary-item">
        <view class="home-summary-label">菜品券</view>
        <view class="home-summary-value">{{hasMember ? '到我的里查看' : '注册后可用'}}</view>
      </view>
    </view>

    <view class="button-group-tight home-summary-actions">
      <button wx:if="{{!hasMember || memberStatusText === '待验证'}}" class="button-primary" bindtap="goRegister">注册会员</button>
      <button wx:else class="button-primary" bindtap="goVouchers">积分和券</button>
      <button class="button-secondary" bindtap="goMine">会员中心</button>
    </view>
  </view>

  <view class="card home-shortcuts-card">
    <view class="card-header-row">
      <view class="card-title-wrap">
        <view class="section-kicker">常用</view>
        <view class="section-title">常用入口</view>
      </view>
      <view class="tag">快捷</view>
    </view>

    <view class="quick-grid home-shortcuts-grid">
      <view class="quick-card home-shortcut-card" bindtap="goMenu">
        <view class="quick-card-tag">点餐</view>
        <view class="quick-card-title">菜单</view>
        <view class="quick-card-copy">按分类选菜。</view>
      </view>

      <view class="quick-card home-shortcut-card" bindtap="goOrders">
        <view class="quick-card-tag">订单</view>
        <view class="quick-card-title">我的订单</view>
        <view class="quick-card-copy">查看状态。</view>
      </view>

      <view class="quick-card home-shortcut-card" bindtap="goMine">
        <view class="quick-card-tag">会员</view>
        <view class="quick-card-title">我的会员</view>
        <view class="quick-card-copy">积分、邀请、券都在这。</view>
      </view>

      <view class="quick-card home-shortcut-card" bindtap="goFeedback">
        <view class="quick-card-tag">反馈</view>
        <view class="quick-card-title">问题反馈</view>
        <view class="quick-card-copy">有问题直接提。</view>
      </view>
    </view>

    <view wx:if="{{categories.length}}" class="home-category-row">
      <view wx:for="{{categories}}" wx:for-item="category" wx:key="_id" class="home-category-chip">{{category.name}}</view>
    </view>
  </view>

</view>
