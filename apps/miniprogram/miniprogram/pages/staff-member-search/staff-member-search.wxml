<view class="page page-tight">
  <view class="hero hero-staff">
    <view class="hero-badge">会员</view>
    <view class="title">会员查询</view>
    <view class="subtitle">查看状态、积分和券。</view>
    <view class="hero-chips">
      <view class="hero-chip">支持手机号</view>
      <view class="hero-chip">支持会员号</view>
      <view class="hero-chip">支持会员码</view>
    </view>
  </view>

  <view class="card">
    <view class="section-head">
      <view class="section-title">搜索会员</view>
      <view class="section-copy">支持手机号、会员号和会员码。</view>
    </view>
    <view class="input-label">手机号 / 会员号</view>
    <input class="input input-strong" placeholder="输入手机号或会员号" value="{{query}}" bindinput="onInput" />
    <view class="button-group-tight">
      <button class="button-secondary" loading="{{scanning}}" disabled="{{loading || scanning}}" bindtap="scanMember">扫码识别会员码</button>
      <button class="button-primary" loading="{{loading}}" disabled="{{loading || scanning}}" bindtap="search">查询</button>
    </view>
  </view>

  <view wx:if="{{hasSearched && !rows.length && !loading}}" class="empty-state">
    <view class="tag">没有匹配结果</view>
    <view class="empty-title">查不到这个会员</view>
    <view class="empty-copy">核对手机号或会员号后再试。</view>
  </view>

  <view wx:if="{{rows.length}}" class="card">
    <view class="section-title">查询结果</view>
    <view wx:for="{{rows}}" wx:key="member._id" class="selection-card">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-title">{{item.member.memberCode}} / {{item.member.phone || '未绑定手机号'}}</view>
          <view class="card-subtitle">{{item.relationLabel}}，{{item.phoneStatusLabel}}</view>
        </view>
        <view class="status-badge {{item.member.hasCompletedFirstVisit ? 'status-ready' : 'status-expired'}}">
          {{item.member.hasCompletedFirstVisit ? '已激活' : '未激活'}}
        </view>
      </view>

      <view class="detail-grid">
        <view class="detail-row">
          <view class="detail-label">首次到店</view>
          <view class="detail-value">{{item.firstVisitLabel}}</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">最近核销</view>
          <view class="detail-value">{{item.latestVisitLabel}}</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">菜品券数量</view>
          <view class="detail-value">总计 {{item.totalVoucherCount}} 张 / 可用 {{item.readyVoucherCount}} 张</view>
        </view>
      </view>
    </view>
  </view>
</view>
