<view class="page">
  <view wx:if="{{!ready}}" class="card">
    <view class="section-title">加载中</view>
    <view class="section-copy">正在获取邀请信息。</view>
  </view>

  <view wx:elif="{{!hasMember}}" class="card">
    <view class="section-title">还没有会员信息</view>
    <view class="section-copy">{{loadError || '请先完成会员注册。'}}</view>
    <navigator class="link-button button-primary" url="/pages/index/index">返回首页</navigator>
  </view>

  <block wx:else>
    <view wx:if="{{loadError}}" class="notice">{{loadError}}</view>

    <view class="hero hero-member">
      <view class="hero-badge">邀请中心</view>
      <view class="title">邀请好友得积分</view>
      <view class="subtitle">好友首单后会计入你的邀请进度。</view>
      <view class="mini-metrics">
        <view class="mini-metric">
          <view class="mini-metric-label">已激活</view>
          <view class="mini-metric-value">{{overview ? overview.activatedCount : 0}}</view>
        </view>
        <view class="mini-metric">
          <view class="mini-metric-label">待激活</view>
          <view class="mini-metric-value">{{overview ? overview.pendingCount : 0}}</view>
        </view>
        <view class="mini-metric">
          <view class="mini-metric-label">状态</view>
          <view class="mini-metric-value">{{relation ? relationStatusText : (canBindInviteCode ? '可绑定' : '可邀请')}}</view>
        </view>
      </view>
    </view>

    <view class="card card-soft">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-kicker">邀请码</view>
          <view class="section-title">{{member.memberCode}}</view>
          <view class="card-subtitle">发给朋友，或者让朋友手动填写。</view>
        </view>
        <view class="tag">{{relation ? relationStatusText : (canBindInviteCode ? '可绑定' : '可邀请')}}</view>
      </view>

      <view class="button-group-tight">
        <button class="button-primary" open-type="share">立即分享</button>
        <button class="button-secondary" bindtap="copyInviteCode">复制邀请码</button>
      </view>
    </view>

    <view class="card card-compact">
      <view class="section-kicker">进度</view>
      <view class="section-title">{{nextMilestoneTitle}}</view>
      <view class="card-subtitle">{{nextMilestoneCopy}}</view>
      <view class="support-strip">
        <view class="support-pill">已激活 {{overview ? overview.activatedCount : 0}} 人</view>
        <view class="support-pill">待激活 {{overview ? overview.pendingCount : 0}} 人</view>
        <view class="support-pill">{{canBindInviteCode ? '首单前可绑定' : '邀请关系已锁定'}}</view>
      </view>
    </view>

    <view class="card">
      <view class="section-kicker">绑定邀请码</view>
      <view class="section-title">手动填写</view>
      <view wx:if="{{relation}}" class="notice">
        当前状态：{{relationStatusText}}
      </view>
      <view wx:elif="{{canBindInviteCode}}">
        <view class="section-copy">首单前可绑定一次邀请码。</view>
        <input
          class="input input-strong"
          placeholder="请输入邀请码"
          value="{{inviteCodeInput}}"
          bindinput="onInviteCodeInput"
        />
        <button class="button-primary" disabled="{{bindingInviteCode || !inviteCodeInput}}" loading="{{bindingInviteCode}}" bindtap="bindInviteCode">确认绑定</button>
      </view>
      <view wx:else class="section-copy">当前不可再绑定邀请码。</view>
    </view>

    <view wx:if="{{overview}}" class="card">
      <view class="section-kicker">积分规则</view>
      <view class="section-title">达标送积分</view>
      <view wx:for="{{overview.milestones}}" wx:key="ruleId" class="list-item">
        <view class="section-title">{{item.title}}</view>
        <view class="card-subtitle">
          {{item.rewardMode === 'REPEATABLE' ? ('每满 ' + item.threshold + ' 人送 ' + item.pointsReward + ' 积分') : (item.threshold + ' 人达标，送 ' + item.pointsReward + ' 积分')}}
        </view>
        <view class="inline-tags">
          <view class="tag {{item.pendingRewardCount > 0 ? 'tag-success' : ''}}">
            {{item.pendingRewardCount > 0 ? ('待到账 ' + (item.pendingRewardCount * item.pointsReward) + ' 积分') : (item.rewardedCount > 0 ? ('已到账 ' + item.rewardedCount + ' 次') : (item.isReached ? '已达标' : '未达标'))}}
          </view>
          <view wx:if="{{item.rewardMode === 'REPEATABLE'}}" class="tag">
            下一次：{{item.nextRewardThreshold}} 人
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
