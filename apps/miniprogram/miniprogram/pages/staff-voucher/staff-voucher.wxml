<view class="page page-tight">
  <view class="hero hero-staff">
    <view class="hero-badge">核销</view>
    <view class="title">菜品券核销</view>
    <view class="subtitle">扫码优先，手输兜底。</view>
    <view class="mini-metrics">
      <view class="mini-metric">
        <view class="mini-metric-label">优先</view>
        <view class="mini-metric-value">扫码核销</view>
      </view>
      <view class="mini-metric">
        <view class="mini-metric-label">兜底</view>
        <view class="mini-metric-value">手输券号</view>
      </view>
      <view class="mini-metric">
        <view class="mini-metric-label">结果</view>
        <view class="mini-metric-value">即时留痕</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-head">
      <view class="section-title">录入券号</view>
      <view class="section-copy">会员出示二维码时可直接扫码。</view>
    </view>

    <view class="input-label">券号</view>
    <input class="input input-strong" placeholder="请输入菜品券号" value="{{voucherId}}" bindinput="onInput" />
    <view class="helper-text">扫不到时再手动输入。</view>

    <view class="button-group">
      <button class="button-secondary" disabled="{{loading || scanning}}" loading="{{scanning}}" bindtap="scanVoucher">扫码核销</button>
      <button class="button-primary" disabled="{{loading || scanning || !voucherId}}" loading="{{loading}}" bindtap="submit">确认核销</button>
    </view>
  </view>

  <view wx:if="{{lastRedeemed}}" class="card card-accent">
    <view class="section-title">最近一次核销</view>
    <view class="detail-grid">
      <view class="detail-row">
        <view class="detail-label">菜品名称</view>
        <view class="detail-value">{{lastRedeemed.dishName}}</view>
      </view>
      <view class="detail-row">
        <view class="detail-label">券号</view>
        <view class="detail-value">{{lastRedeemed._id}}</view>
      </view>
      <view class="detail-row">
        <view class="detail-label">状态</view>
        <view class="detail-value">已核销</view>
      </view>
    </view>
  </view>
</view>
