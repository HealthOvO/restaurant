<view class="page page-tight">
  <view class="hero hero-member">
    <view class="hero-badge">活动规则</view>
    <view class="title">会员玩法</view>
    <view class="subtitle">注册、邀请、积分和用券都在这里。</view>
    <view class="mini-metrics">
      <view class="mini-metric">
        <view class="mini-metric-label">我的邀请码</view>
        <view class="mini-metric-value">{{memberCode || '待注册'}}</view>
      </view>
      <view class="mini-metric">
        <view class="mini-metric-label">邀请奖励</view>
        <view class="mini-metric-value">积分</view>
      </view>
      <view class="mini-metric">
        <view class="mini-metric-label">券使用</view>
        <view class="mini-metric-value">到店核销</view>
      </view>
    </view>
  </view>

  <view class="card card-soft">
    <view class="section-title">怎么参与</view>
    <view class="rule-flow">
      <view class="rule-flow-item">
        <view class="tag">01</view>
        <view class="rule-flow-copy">先注册会员，并完成微信手机号验证。</view>
      </view>
      <view class="rule-flow-item">
        <view class="tag">02</view>
        <view class="rule-flow-copy">邀请朋友，或在自己首单前填写朋友的邀请码。</view>
      </view>
      <view class="rule-flow-item">
        <view class="tag">03</view>
        <view class="rule-flow-copy">被邀请人完成首单后，邀请进度会自动增加。</view>
      </view>
      <view class="rule-flow-item">
        <view class="tag">04</view>
        <view class="rule-flow-copy">积分可以换券，到店给店员扫码就能用。</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">常见问题</view>

    <view class="rule-card">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-title">怎么成为会员？</view>
          <view class="card-subtitle">到店后完成微信手机号验证，会员号会自动生成。</view>
        </view>
        <view class="tag">注册</view>
      </view>
      <view class="detail-grid">
        <view class="detail-row">
          <view class="detail-label">当前邀请码</view>
          <view class="detail-value">{{memberCode || '注册后生成'}}</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">绑定时机</view>
          <view class="detail-value">首单前可绑邀请人，首单后锁定</view>
        </view>
      </view>
    </view>

    <view class="rule-card">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-title">邀请什么时候算成功？</view>
          <view class="card-subtitle">朋友先绑定你，再完成首单，邀请进度才会增加。</view>
        </view>
        <view class="tag tag-success">邀请</view>
      </view>
      <view class="detail-grid">
        <view class="detail-row">
          <view class="detail-label">生效条件</view>
          <view class="detail-value">被邀请人完成首单</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">到账方式</view>
          <view class="detail-value">邀请积分自动到账</view>
        </view>
      </view>
    </view>

    <view class="rule-card">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-title">积分从哪里来？</view>
          <view class="card-subtitle">邀请成功、老板补偿等都会记到积分里。</view>
        </view>
        <view class="tag">积分</view>
      </view>
      <view class="detail-grid">
        <view class="detail-row">
          <view class="detail-label">查看位置</view>
          <view class="detail-value">“积分和券”里能看余额和流水</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">使用方式</view>
          <view class="detail-value">积分先换券，再到店核销</view>
        </view>
      </view>
    </view>

    <view class="rule-card">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-title">券怎么用？</view>
          <view class="card-subtitle">兑换成功后会到账 1 张券，到店出示二维码或券号即可。</view>
        </view>
        <view class="tag tag-success">用券</view>
      </view>
      <view class="detail-grid">
        <view class="detail-row">
          <view class="detail-label">使用场景</view>
          <view class="detail-value">仅限堂食核销</view>
        </view>
        <view class="detail-row">
          <view class="detail-label">过期或已核销</view>
          <view class="detail-value">不能恢复，如需补偿会补发新券</view>
        </view>
      </view>
    </view>
  </view>
</view>
