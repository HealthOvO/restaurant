.mode-switch-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.mode-pill {
  flex: 1;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  background: #fbf4ea;
  color: #6c5943;
  border: 1rpx solid #e8d7c1;
}

.mode-pill-active {
  background: #9a3529;
  border-color: #9a3529;
  color: #ffffff;
}
