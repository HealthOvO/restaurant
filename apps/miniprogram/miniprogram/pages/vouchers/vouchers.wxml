<view class="page page-tight">
  <view wx:if="{{!ready}}" class="card">
    <view class="section-title">正在同步菜品券</view>
      <view class="section-copy">正在刷新积分和券。</view>
  </view>

  <view wx:elif="{{!hasMember}}" class="card">
    <view class="section-title">还没有会员资料</view>
    <view class="section-copy">{{loadError || '请先回首页完成会员注册，注册后这里会显示你的菜品券。'}}</view>
    <navigator class="link-button button-primary" url="/pages/index/index">返回首页</navigator>
  </view>

  <block wx:else>
    <view wx:if="{{loadError}}" class="notice">{{loadError}}</view>

    <view class="hero hero-member">
      <view class="hero-badge">积分与菜品券</view>
      <view class="title">积分和券</view>
      <view class="subtitle">积分够了就换券，到店给店员扫码。</view>
      <view class="mini-metrics">
        <view class="mini-metric">
          <view class="mini-metric-label">当前积分</view>
          <view class="mini-metric-value">{{pointsBalance}}</view>
        </view>
        <view class="mini-metric">
          <view class="mini-metric-label">待使用券</view>
          <view class="mini-metric-value">{{readyCount}}</view>
        </view>
        <view class="mini-metric">
          <view class="mini-metric-label">已核销</view>
          <view class="mini-metric-value">{{usedCount}}</view>
        </view>
      </view>
      <view class="hero-chips">
        <view class="hero-chip">积分兑换</view>
        <view class="hero-chip">到店核销</view>
      </view>
    </view>

    <view class="card card-soft card-compact">
      <view class="card-header-row">
        <view class="card-title-wrap">
          <view class="section-kicker">怎么用</view>
          <view class="section-title">先换券，再核销</view>
          <view class="card-subtitle">兑换后会到账 1 张券，现场出示二维码或券号都可以。</view>
        </view>
        <view class="tag {{pointsBalance > 0 ? 'tag-success' : ''}}">{{pointsBalance > 0 ? ('当前 ' + pointsBalance + ' 积分') : '暂无积分'}}</view>
      </view>

      <view class="usage-list">
        <view class="usage-item">
          <view class="usage-title">积分足够就能换</view>
          <view class="usage-copy">兑换成功后会立刻扣积分。</view>
        </view>
        <view class="usage-item">
          <view class="usage-title">到店出示二维码</view>
          <view class="usage-copy">扫不到时，直接报券号也可以。</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-kicker">积分兑换</view>
      <view class="section-title">可兑换菜品</view>
      <view class="section-copy">积分够了就能换。</view>

      <view wx:if="{{!exchangeItems.length}}" class="empty-state">
        <view class="tag">暂无兑换菜品</view>
        <view class="empty-title">还没有可兑换菜品</view>
        <view class="empty-copy">可以先去邀请好友攒积分。</view>
      </view>

      <view wx:for="{{exchangeItems}}" wx:key="_id" class="voucher-card">
        <view class="card-header-row">
          <view class="card-title-wrap">
            <view class="section-title">{{item.voucherTemplate.dishName}}</view>
            <view class="card-subtitle">{{item.name}}</view>
          </view>
          <view class="status-badge {{pointsBalance >= item.pointsCost ? 'status-ready' : 'status-expired'}}">{{item.pointsCostText}}</view>
        </view>

        <view class="detail-grid">
          <view class="detail-row">
            <view class="detail-label">有效期</view>
            <view class="detail-value">{{item.validDaysText}}</view>
          </view>
          <view class="detail-row">
            <view class="detail-label">兑换后形式</view>
            <view class="detail-value">到账 1 张菜品券</view>
          </view>
        </view>

        <view class="button-group-tight voucher-action-row">
          <button
            class="button-primary"
            data-exchange-item-id="{{item._id}}"
            disabled="{{redeemingItemId || pointsBalance < item.pointsCost}}"
            loading="{{redeemingItemId === item._id}}"
            bindtap="redeemExchangeItem"
          >
            {{pointsBalance >= item.pointsCost ? '立即兑换' : '积分不足'}}
          </button>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-kicker">到账记录</view>
      <view class="section-title">券列表</view>
      <view class="section-copy">每张券都有独立券号。</view>

      <view wx:if="{{loading}}" class="notice">正在同步最新菜品券...</view>

      <view wx:if="{{!loading && !vouchers.length}}" class="empty-state">
        <view class="tag">暂无菜品券</view>
        <view class="empty-title">还没有菜品券</view>
        <view class="empty-copy">首单或积分兑换后会到账。</view>
        <navigator class="link-button button-secondary" url="/pages/invite/invite">去查看邀请进度</navigator>
      </view>

      <view wx:for="{{vouchers}}" wx:key="_id" class="voucher-card {{item.statusClass}}">
        <view class="card-header-row">
          <view class="card-title-wrap">
            <view class="section-title">{{item.dishName}}</view>
            <view class="card-subtitle">{{item.sourceText}}</view>
          </view>
          <view class="status-badge {{item.statusClass}}">{{item.statusText}}</view>
        </view>

        <view class="code-panel">
          <view class="code-label">核销券号</view>
          <view class="code-value code-value-small">{{item._id}}</view>
          <view class="code-caption">店员扫码或输入券号都可以核销。</view>
        </view>

        <view class="detail-grid">
          <view class="detail-row">
            <view class="detail-label">有效期至</view>
            <view class="detail-value">{{item.expiresAtLabel}}</view>
          </view>
          <view class="detail-row">
            <view class="detail-label">使用限制</view>
            <view class="detail-value">仅限堂食核销</view>
          </view>
          <view wx:if="{{item.usedAtLabel}}" class="detail-row">
            <view class="detail-label">核销时间</view>
            <view class="detail-value">{{item.usedAtLabel}}</view>
          </view>
        </view>

        <view class="button-group-tight voucher-action-row">
          <button
            wx:if="{{item.status === 'READY'}}"
            class="button-primary"
            data-voucher-id="{{item._id}}"
            bindtap="showVoucherQr"
          >
            展示二维码
          </button>
          <button class="button-secondary" data-voucher-id="{{item._id}}" bindtap="copyVoucherId">复制券号</button>
        </view>
      </view>
    </view>

    <view wx:if="{{pointTransactions.length}}" class="card card-compact">
      <view class="section-kicker">积分记录</view>
      <view class="section-title">最近积分变动</view>
      <view wx:for="{{pointTransactions}}" wx:key="_id" class="list-item">
        <view class="card-header-row">
          <view class="card-title-wrap">
            <view class="section-title">{{item.typeText}}</view>
            <view class="card-subtitle">{{item.note || '系统记录'}}</view>
          </view>
          <view class="status-badge {{item.changeAmount > 0 ? 'status-ready' : 'status-used'}}">{{item.changeText}}</view>
        </view>
        <view class="detail-grid">
          <view class="detail-row">
            <view class="detail-label">记录时间</view>
            <view class="detail-value">{{item.createdAtLabel}}</view>
          </view>
          <view class="detail-row">
            <view class="detail-label">变动后余额</view>
            <view class="detail-value">{{item.balanceAfter}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="card card-compact">
      <view class="section-kicker">提醒</view>
      <view class="section-title">用券说明</view>
      <view class="tip-stack">
        <view class="tip-row">
          <view class="tip-badge">有效期</view>
          <view class="tip-body">
            <view class="tip-title">过期后不能恢复</view>
            <view class="tip-copy">如果要补偿，门店会补发新券。</view>
          </view>
        </view>
        <view class="tip-row">
          <view class="tip-badge">核销后</view>
          <view class="tip-body">
            <view class="tip-title">已核销的券不能再用</view>
            <view class="tip-copy">再次扫码或输入同一券号会被拦截。</view>
          </view>
        </view>
        <view class="tip-row">
          <view class="tip-badge">现场</view>
          <view class="tip-body">
            <view class="tip-title">现场只认二维码或券号</view>
            <view class="tip-copy">兑换成功后再到店使用。</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{qrPreviewVisible && qrPreviewVoucher}}" class="overlay-mask" catchtouchmove="noop" bindtap="hideVoucherQr">
      <view class="dialog-sheet qr-dialog" catchtap="noop">
        <view class="section-title">向店员出示这张券</view>
        <view class="section-copy">店员扫码后会直接核销。</view>

        <view class="qr-preview-shell">
          <canvas
            canvas-id="{{qrCanvasId}}"
            class="voucher-qr-canvas"
            disable-scroll="true"
            style="width: 420rpx; height: 420rpx;"
            width="{{qrCanvasSize}}"
            height="{{qrCanvasSize}}"
          ></canvas>
        </view>

        <view class="detail-grid">
          <view class="detail-row">
            <view class="detail-label">菜品</view>
            <view class="detail-value">{{qrPreviewVoucher.dishName}}</view>
          </view>
          <view class="detail-row">
            <view class="detail-label">券号</view>
            <view class="detail-value">{{qrPreviewVoucher._id}}</view>
          </view>
          <view class="detail-row">
            <view class="detail-label">有效期至</view>
            <view class="detail-value">{{qrPreviewVoucher.expiresAtLabel}}</view>
          </view>
        </view>

        <view class="button-group-tight">
          <button class="button-secondary" data-voucher-id="{{qrPreviewVoucher._id}}" bindtap="copyVoucherId">复制券号</button>
          <button class="button-primary" bindtap="hideVoucherQr">收起二维码</button>
        </view>
      </view>
    </view>
  </block>
</view>
