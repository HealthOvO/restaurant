<view class="page page-tight">
  <view class="hero hero-staff">
    <view class="hero-badge">订单</view>
    <view class="title">门店订单</view>
    <view class="subtitle">看订单并更新状态。</view>

    <view class="summary-chip-grid">
      <view class="summary-chip-card">
        <view class="summary-chip-label">待接单</view>
        <view class="summary-chip-value">{{pendingCount}}</view>
      </view>
      <view class="summary-chip-card">
        <view class="summary-chip-label">已确认</view>
        <view class="summary-chip-value">{{confirmedCount}}</view>
      </view>
      <view class="summary-chip-card">
        <view class="summary-chip-label">制作中</view>
        <view class="summary-chip-value">{{preparingCount}}</view>
      </view>
      <view class="summary-chip-card">
        <view class="summary-chip-label">待取餐</view>
        <view class="summary-chip-value">{{readyCount}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-kicker">筛选</view>
    <view class="section-title">搜索订单</view>
    <view class="section-copy">支持订单号、会员号、联系人、手机号和桌号。</view>

    <view class="search-row">
      <input class="input input-strong search-input" value="{{keyword}}" placeholder="输入订单号、会员号、桌号或手机号" bindinput="onInput" />
      <button class="button-primary search-button" bindtap="search">搜索</button>
    </view>
    <button wx:if="{{keyword}}" class="button-secondary search-clear" bindtap="clearSearch">清空检索</button>

    <scroll-view class="status-filter-scroll" scroll-x="true" enable-flex="true">
      <view class="status-filter-row">
        <view wx:for="{{statusFilters}}" wx:for-item="statusOption" wx:key="value" class="status-filter-chip {{activeStatus === statusOption.value ? 'status-filter-chip-active' : ''}}" data-status="{{statusOption.value}}" bindtap="setStatus">
          {{statusOption.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="card">
    <view class="section-title">加载中</view>
    <view class="section-copy">正在同步订单。</view>
  </view>

  <view wx:if="{{errorMessage}}" class="card card-accent">
    <view class="section-title">提示</view>
    <view class="notice">{{errorMessage}}</view>
    <button class="button-secondary" bindtap="search">重新加载</button>
  </view>

  <view wx:if="{{!loading && !orders.length}}" class="empty-state">
    <view class="tag tag-navy">当前没有订单</view>
    <view class="empty-title">没有匹配订单</view>
    <view class="empty-copy">换个筛选条件试试。</view>
  </view>

  <view wx:for="{{orders}}" wx:for-item="order" wx:key="_id" class="card">
    <view class="card-header-row">
      <view class="card-title-wrap">
        <view class="section-title">{{order.orderNo}}</view>
        <view class="card-subtitle">{{order.memberLabel}} · {{order.locationLabel}}</view>
      </view>
      <view class="{{order.statusBadgeClass}}">{{order.statusText}}</view>
    </view>

    <view class="detail-grid">
      <view class="detail-row">
        <view class="detail-label">下单时间</view>
        <view class="detail-value">{{order.submittedAtLabel}}</view>
      </view>
      <view class="detail-row">
        <view class="detail-label">订单内容</view>
        <view class="detail-value">{{order.itemSummary || '查看详情'}}</view>
      </view>
      <view class="detail-row">
        <view class="detail-label">数量 / 金额</view>
        <view class="detail-value">{{order.itemCount}} 件 · ¥{{order.payableAmountText}}</view>
      </view>
    </view>

    <button class="button-primary" data-order-id="{{order._id}}" bindtap="goDetail">查看并处理</button>
  </view>
</view>
